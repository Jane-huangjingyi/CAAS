# -------------------------------
# 1. Load packages
# -------------------------------
library(phyloseq)
library(curatedMetagenomicData)
library(vegan)
library(cluster)
library(mixOmics)
library(randomForest)
library(iml)       # SHAP解释
library(dplyr)
library(pheatmap)
